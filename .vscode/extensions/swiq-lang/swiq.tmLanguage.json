{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Swiq",
  "scopeName": "source.swiq",
  "patterns": [
    {
      "name": "comment.block.swiq",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "comment.line.double-slash.swiq",
      "match": "//.*$"
    },
    {
      "name": "comment.line.number-sign.swiq",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.double.swiq",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "meta.function.declaration.swiq",
      "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^)]*)\\)",
      "captures": {
        "1": { "name": "storage.type.function.swiq" },
        "2": { "name": "entity.name.function.swiq" },
        "3": { "name": "variable.parameter.swiq" }
      }
    },
    {
      "name": "meta.variable.declaration.swiq",
      "match": "\\b(set)\\s+(?:(local|global)\\s+)?(var)\\s*(<Protected>)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "storage.modifier.swiq" },
        "2": { "name": "storage.modifier.swiq" },
        "3": { "name": "storage.modifier.swiq" },
        "4": { "name": "storage.type.modifier.swiq" },
        "5": { "name": "variable.other.assignment.swiq" }
      }
    },
    {
      "name": "meta.variable.assignment.swiq",
      "match": "\\b(set)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "storage.modifier.swiq" },
        "2": { "name": "variable.other.assignment.swiq" }
      }
    },
    {
      "name": "keyword.control.loop.swiq",
      "match": "\\b(if|else|while|for|return)\\b"
    },
    {
      "name": "storage.modifier.swiq",
      "match": "\\b(set|var|local|global)\\b"
    },
    {
      "name": "storage.type.modifier.swiq",
      "match": "<Protected>"
    },
    {
      "name": "constant.language.swiq",
      "match": "\\b(true|false|null|none)\\b"
    },
    {
      "name": "support.function.builtin.swiq",
      "match": "\\b(log|len|push|AllocatedArray|readFile)\\b"
    },
    {
      "name": "constant.numeric.swiq",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  ]
}

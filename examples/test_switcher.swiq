set local var myVar = "apple";

func print(l) {
    log(l);
}

switcher(myVar):
  is "banana":
    print("Found banana");
    destroy;
  is "apple":
    print("Found apple perfectly!");
    destroy;
    print("ERROR: This line inside 'is' should be skipped by destroy");
  is "orange":
    print("Found orange");
    destroy;

print("Switcher exited to parent scope.");

set local var score = 100;
switcher(score):
  is 50:
    print("Score is 50");
    destroy;
  is 100:
    print("Score is 100! Max score!");
    destroy;
